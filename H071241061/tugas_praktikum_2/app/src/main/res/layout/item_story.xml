<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp">

        <!-- Ring gradient — ukuran penuh -->
        <View
            android:id="@+id/viewRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_border_story" />

        <!-- ✅ FIX: hapus padding, hapus background, ukuran 64dp (lebih kecil dari ring 72dp) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgStory"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            tools:src="@tools:sample/avatars" />

        <!-- Tombol + biru untuk your story -->
        <FrameLayout
            android:id="@+id/btnAddStory"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_blue_plus"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

        </FrameLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/tvLabel"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="username"
        android:textColor="#000000"
        android:textSize="11sp" />

</LinearLayout>